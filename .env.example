# Environment Configuration for MigiSignals
# Copy this file to .env and fill in your values

# Deriv API
DERIV_API_TOKEN=your_token_here
DERIV_APP_ID=1089
DERIV_SYMBOL=1HZ10V

# Server
WS_PORT=8080

# Trading Configuration
BASE_STAKE=1.00
TARGET_PROFIT=50
STOP_LOSS=20
MAX_CONSECUTIVE_LOSSES=7

# Mode: true = simulator (no real trades), false = live trading
SIMULATOR_MODE=true

# Database
DATABASE_URL=file:./dev.db
